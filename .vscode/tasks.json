{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "pnpm",
            "args": ["build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$tsc"]
        },
        {
            "label": "build:watch",
            "type": "shell",
            "command": "pnpm",
            "args": ["build:watch"],
            "isBackground": true,
            "problemMatcher": ["$tsc-watch"]
        },
        {
            "label": "test",
            "type": "shell",
            "command": "pnpm",
            "args": ["test"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "pnpm",
            "args": ["lint"],
            "problemMatcher": ["$eslint-stylish"]
        },
        {
            "label": "grammar",
            "type": "shell",
            "command": "pnpm",
            "args": ["--dir", "packages/syside-languageserver", "grammar"]
        }
    ]
}
