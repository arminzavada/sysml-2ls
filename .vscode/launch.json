{
    "version": "0.2.0",
    "compounds": [
        {
            "name": "Run Extension and Attach a Debugger",
            "configurations": [
                "Run Extension and Break",
                "Attach to Language Server"
            ],
            "stopAll": true
        }
    ],
    "configurations": [
        {
            "name": "Debug KerML AST",
            "program": "${workspaceFolder}/packages/syside-cli/lib/src/index.js",
            "args": [
                "dump",
                "${workspaceFolder}/test.kerml",
                "-v",
                "-l",
                "none"
            ],
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Debug SysML AST",
            "program": "${workspaceFolder}/packages/syside-cli/lib/src/index.js",
            "args": [
                "dump",
                "${workspaceFolder}/test.sysml",
                "-v",
                "-l",
                "none"
            ],
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/packages/syside-vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/*/dist/**/*.js",
                "${workspaceFolder}/packages/*/lib/**/*.js",
                "!**/node_modules/**"
            ],
            "env": {
                "DEBUG_SOCKET": "8008"
            }
        },
        {
            "name": "Run Web Extension",
            "type": "extensionHost",
            "debugWebWorkerHost": true,
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/packages/syside-vscode",
                "--extensionDevelopmentKind=web"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/*/dist/**/*.js",
                "${workspaceFolder}/packages/*/lib/**/*.js",
                "!**/node_modules/**"
            ],
            "env": {
                "DEBUG_SOCKET": "8008"
            }
        },
        {
            "name": "Run Extension and Break",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/packages/syside-vscode"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/*/dist/**/*.js",
                "${workspaceFolder}/packages/*/lib/**/*.js",
                "!**/node_modules/**"
            ],
            "env": {
                "DEBUG_BREAK": "true",
                "DEBUG_SOCKET": "8008"
            }
        },
        {
            "name": "Attach to Language Server",
            "type": "node",
            "port": 8008,
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/packages/*/dist/**/*.js",
                "${workspaceFolder}/node_modules/langium"
            ],
            "timeout": 120000,
            "restart": true
        }
    ]
}
