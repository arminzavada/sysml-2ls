{
  "compilerOptions": {
    "incremental": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ESNext",
      "DOM",
      "webworker"
    ],
    "declaration": true,
    "declarationMap": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "outDir": "lib",
    "composite": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "moduleResolution": "Bundler",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "out",
    "lib",
    "node_modules"
  ]
}
