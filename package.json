{
    "name": "syside-packages",
    "private": true,
    "publisher": "Sensmetry",
    "author": {
        "name": "Sensmetry",
        "url": "https://sensmetry.com/",
        "email": "opensource@sensmetry.com"
    },
    "version": "0.9.1",
    "repository": {
        "url": "https://github.com/arminzavada/sysml-2ls",
        "type": "git"
    },
    "bugs": {
        "url": "https://github.com/arminzavada/sysml-2ls/issues"
    },
    "scripts": {
        "clean": "shx rm -rf packages/*/lib packages/*/out packages/*/dist packages/*/coverage packages/**/*.tsbuildinfo *.tsbuildinfo coverage",
        "prebuild": "pnpm -r --if-present prebuild",
        "build": "pnpm prebuild && tsc -b tsconfig.build.json && pnpm --dir packages/syside-vscode build",
        "watch": "pnpm prebuild && concurrently -n tsc,vscode -c blue,yellow \"tsc -b tsconfig.build.json -w\" \"pnpm --dir packages/syside-vscode watch\"",
        "lint": "eslint packages --max-warnings 0",
        "test": "vitest run",
        "test:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile=junit.xml",
        "vscode:package": "pnpm --dir packages/syside-vscode run vscode:package",
        "grammar:generate": "pnpm --dir packages/syside-languageserver grammar:generate",
        "grammar:watch": "pnpm --dir packages/syside-languageserver grammar:watch",
        "clone-stdlib": "pnpm --dir packages/syside-languageserver clone-stdlib",
        "update-stdlib": "node ./scripts/update-stdlib.mjs",
        "index": "pnpm -r --if-present index"
    },
    "pnpm": {
        "overrides": {
            "typescript": "5.8.3"
        }
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "~22.18.0",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/expect": "^3.2.4",
        "commander": "^14.0.3",
        "concurrently": "^9.2.1",
        "esbuild": "^0.25.0",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "fs-extra": "^11.3.5",
        "globals": "^15.15.0",
        "node-stdlib-browser": "^1.3.1",
        "prettier": "^3.8.3",
        "rollup-plugin-license": "^3.7.1",
        "shx": "^0.4.0",
        "tsx": "^4.22.0",
        "typescript": "5.8.3",
        "typescript-eslint": "^8.46.4",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=20.11.0"
    }
}
