{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "lib",
        "baseUrl": ".",
        "paths": {
            "#generated/*": ["./gen/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "gen/**/*.ts"
    ],
    "files": ["package.json"],
    "exclude": [
        "lib",
        "node_modules",
        "**/__test__",
        "**/__tests__"
    ],
    "references": [
        {
            "path": "../syside-base"
        },
        {
            "path": "../syside-protocol"
        }
    ]
}