{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "lib",
        "baseUrl": ".",
        "paths": {
            // chevrotain 9.x's `package.json#exports` omits a `types`
            // condition, so under `moduleResolution: Bundler` TypeScript
            // cannot reach the bundled `chevrotain.d.ts`. Pin the types
            // import to the declaration file directly until the Langium
            // 1→2 hop replaces chevrotain.
            "chevrotain": ["./node_modules/chevrotain/chevrotain.d.ts"]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "lib",
        "node_modules",
        "**/__test__",
        "**/__tests__"
    ],
    "references": [
        {
            "path": "../syside-base"
        },
        {
            "path": "../syside-protocol"
        }
    ]
}