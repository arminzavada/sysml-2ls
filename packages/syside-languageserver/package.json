{
    "name": "syside-languageserver",
    "displayName": "SysIDE",
    "description": "SysML v2 language server.",
    "publisher": "Sensmetry",
    "author": {
        "name": "Sensmetry",
        "url": "https://sensmetry.com/",
        "email": "opensource@sensmetry.com"
    },
    "version": "0.9.1",
    "keywords": [
        "SysML",
        "KerML",
        "SysML-v2"
    ],
    "preview": true,
    "repository": {
        "url": "https://github.com/arminzavada/sysml-2ls",
        "type": "git",
        "directory": "packages/syside-languageserver"
    },
    "bugs": {
        "url": "https://github.com/arminzavada/sysml-2ls/issues"
    },
    "type": "module",
    "files": [
        "dist",
        "lib",
        "gen",
        "src"
    ],
    "bin": {
        "syside": "./dist/syside-languageserver.cjs"
    },
    "main": "./lib/src/index.js",
    "exports": {
        ".": "./lib/src/index.js",
        "./node.js": "./lib/src/node/index.js",
        "./node/main.js": "./lib/src/node/main.js",
        "./browser.js": "./lib/src/browser/index.js",
        "./browser/main.js": "./lib/src/browser/main.js",
        "./package.json": "./package.json"
    },
    "imports": {
        "#generated/*.js": {
            "development": "./gen/*.ts",
            "default": "./lib/gen/*.js"
        },
        "#generated/*": {
            "development": "./gen/*.ts",
            "default": "./lib/gen/*.js"
        }
    },
    "scripts": {
        "clean": "shx rm -rf dist lib coverage *.tsbuildinfo gen syntaxes/kerml.tmLanguage.json syntaxes/sysml.tmLanguage.json",
        "grammar": "langium generate",
        "grammar:watch": "langium generate --watch",
        "typecheck": "pnpm grammar && tsc -b tsconfig.test.json",
        "typecheck:watch": "tsc -b tsconfig.test.json --watch",
        "lint": "eslint src --max-warnings 0",
        "check": "pnpm typecheck && pnpm lint",
        "assemble": "pnpm grammar && tsc",
        "assemble:watch": "tsc --watch",
        "bundle": "node esbuild.mjs --minify",
        "bundle:watch": "node esbuild.mjs --sourcemap --watch",
        "build": "pnpm check && pnpm assemble && pnpm bundle",
        "build:watch": "concurrently -n tsc,esbuild -c blue,yellow \"pnpm assemble:watch\" \"pnpm bundle:watch\"",
        "test": "vitest run"
    },
    "dependencies": {
        "chevrotain": "~12.0.0",
        "commander": "^14.0.3",
        "langium": "~4.2.4",
        "node-fetch": "^3.3.2",
        "performance-now": "^2.1.0",
        "string-width": "^8.2.1",
        "syside-base": "workspace:*",
        "syside-protocol": "workspace:*",
        "ts-mixer": "^6.0.3",
        "vscode-languageserver": "~9.0.1",
        "vscode-languageserver-textdocument": "~1.0.12",
        "vscode-uri": "~3.1.0"
    },
    "devDependencies": {
        "chalk": "^5.6.2",
        "langium-cli": "~4.2.1",
        "syside-languageclient": "workspace:*",
        "typescript-string-operations": "^1.6.1"
    }
}
