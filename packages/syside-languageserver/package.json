{
    "name": "syside-languageserver",
    "displayName": "SysIDE",
    "description": "SysML v2 language server.",
    "publisher": "Sensmetry",
    "author": {
        "name": "Sensmetry",
        "url": "https://sensmetry.com/",
        "email": "opensource@sensmetry.com"
    },
    "version": "0.9.1",
    "keywords": [
        "SysML",
        "KerML",
        "SysML-v2"
    ],
    "preview": true,
    "repository": {
        "url": "https://github.com/arminzavada/sysml-2ls",
        "type": "git",
        "directory": "packages/syside-languageserver"
    },
    "bugs": {
        "url": "https://github.com/arminzavada/sysml-2ls/issues"
    },
    "type": "module",
    "files": [
        "bin",
        "out",
        "lib",
        "src"
    ],
    "bin": {
        "syside": "./bin/syside-languageserver"
    },
    "main": "./lib/index.js",
    "scripts": {
        "prebuild": "shx rm -rf ../syside-vscode/syntaxes && shx cp -R ./syntaxes ../syside-vscode/syntaxes && cd src && node -p \"'export const Version = ' + JSON.stringify(require('../package.json').version) + ';'\" > version.ts",
        "clean": "shx rm -rf out lib coverage *.tsbuildinfo",
        "build": "pnpm prebuild && tsc",
        "watch": "pnpm prebuild && tsc --watch",
        "lint": "eslint src --max-warnings 0",
        "test": "vitest run",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
        "index": "node ../../scripts/generate-index.mjs src/model src/testing src/node src/services src/utils src/launch src/browser",
        "esbuild": "pnpm prebuild && node ../../scripts/build.mjs node src/node/main.ts --sourcemap",
        "esbuild:watch": "pnpm esbuild --watch",
        "esbuild:browser": "pnpm prebuild && node ../../scripts/build.mjs browser src/browser/main.ts",
        "grammar:generate": "langium generate && shx rm -rf ../syside-vscode/syntaxes && shx cp -R ./syntaxes ../syside-vscode/syntaxes",
        "grammar:watch": "langium generate --watch",
        "clone-stdlib": "node ./scripts/clone-sysml-release.mjs"
    },
    "dependencies": {
        "chevrotain": "~12.0.0",
        "commander": "^14.0.3",
        "langium": "~4.2.4",
        "node-fetch": "^3.3.2",
        "performance-now": "^2.1.0",
        "string-width": "^8.2.1",
        "syside-base": "workspace:*",
        "syside-protocol": "workspace:*",
        "ts-mixer": "^6.0.3",
        "vscode-languageserver": "~9.0.1",
        "vscode-languageserver-textdocument": "~1.0.12",
        "vscode-uri": "~3.1.0"
    },
    "devDependencies": {
        "chalk": "^5.6.2",
        "langium-cli": "~4.2.1",
        "syside-languageclient": "workspace:*",
        "typescript-string-operations": "^1.6.1"
    }
}
