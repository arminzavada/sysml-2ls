{
    "name": "syside-cli",
    "displayName": "SysIDE-CLI",
    "description": "CLI for SysIDE.",
    "publisher": "Sensmetry",
    "author": {
        "name": "Sensmetry",
        "url": "https://sensmetry.com/",
        "email": "opensource@sensmetry.com"
    },
    "version": "0.9.1",
    "preview": true,
    "repository": {
        "url": "https://github.com/arminzavada/sysml-2ls",
        "type": "git",
        "directory": "packages/syside-cli"
    },
    "bugs": {
        "url": "https://github.com/arminzavada/sysml-2ls/issues"
    },
    "type": "module",
    "files": [
        "dist",
        "lib",
        "src"
    ],
    "bin": {
        "syside-cli": "./dist/cli.cjs"
    },
    "main": "./lib/src/index.js",
    "scripts": {
        "clean": "shx rm -rf dist lib coverage *.tsbuildinfo",
        "typecheck": "tsc -b tsconfig.test.json",
        "typecheck:watch": "tsc -b tsconfig.test.json --watch",
        "lint": "eslint src --max-warnings 0",
        "check": "pnpm typecheck && pnpm lint",
        "assemble": "tsc -b",
        "assemble:watch": "tsc -b --watch",
        "bundle": "pnpm assemble && node esbuild.mjs --minify",
        "bundle:watch": "node esbuild.mjs --sourcemap --watch",
        "build": "pnpm check && pnpm assemble && pnpm bundle",
        "build:watch": "concurrently -n tsc,esbuild -c blue,yellow \"pnpm assemble:watch\" \"pnpm bundle:watch\"",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "syside-languageserver": "workspace:*",
        "vscode-uri": "~3.1.0"
    },
    "devDependencies": {
        "langium": "~4.2.4",
        "vscode-languageserver": "~9.0.1"
    }
}
