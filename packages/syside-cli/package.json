{
    "name": "syside-cli",
    "displayName": "SysIDE-CLI",
    "description": "CLI for SysIDE.",
    "publisher": "Sensmetry",
    "author": {
        "name": "Sensmetry",
        "url": "https://sensmetry.com/",
        "email": "opensource@sensmetry.com"
    },
    "version": "0.9.1",
    "preview": true,
    "repository": {
        "url": "https://github.com/arminzavada/sysml-2ls",
        "type": "git",
        "directory": "packages/syside-cli"
    },
    "bugs": {
        "url": "https://github.com/arminzavada/sysml-2ls/issues"
    },
    "type": "module",
    "files": [
        "bin",
        "out",
        "lib",
        "src"
    ],
    "main": "./lib/index.js",
    "scripts": {
        "prebuild": "cd src && node -p \"'export const Version = ' + JSON.stringify(require('../package.json').version) + ';'\" > version.ts",
        "clean": "shx rm -rf out lib coverage *.tsbuildinfo",
        "build": "pnpm prebuild && tsc",
        "watch": "tsc --watch",
        "lint": "eslint src --max-warnings 0",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
        "esbuild": "node ../../scripts/build.mjs node src/index.ts --sourcemap",
        "esbuild:watch": "pnpm esbuild --watch"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "syside-languageserver": "workspace:*",
        "vscode-uri": "~3.1.0"
    },
    "devDependencies": {
        "langium": "~4.2.4",
        "vscode-languageserver": "~9.0.1"
    }
}
